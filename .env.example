SECRET_KEY=buraya_guclu_secret_key_yaz
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=buraya_generate_password_hash_ciktisi_yaz

FLASK_DEBUG=False
APP_ENV=production
SESSION_COOKIE_SECURE=True
ALLOW_INIT_DB=False

# PostgreSQL kullanacaksan Render/hosting panelinden ekle:
# DATABASE_URL=postgresql://...

# Supabase / PostgreSQL
# Render gibi IPv4-only ortamlarda Supabase pooler URL kullan:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DB_NULLPOOL=1
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10

# Cloudinary görsel yükleme
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=dyt-misra-cakir

# Upload limiti
MAX_UPLOAD_MB=6

FORCE_HTTPS=True

TRUST_PROXY_HEADERS=True

MAX_FORM_FIELD_LENGTH=5000
